# ─── Supabase (트랙 B 백엔드) ───────────────────────────────
# Supabase 대시보드 > Project Settings > API 에서 복사
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
# 서버 전용(절대 클라이언트 노출 금지). 관리 작업/시드에만 사용
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# ─── 토스페이먼츠 (명태 충전 PG) ────────────────────────────
# 토스페이먼츠 개발자센터(developers.tosspayments.com) > 내 개발정보 > 테스트 키
# 클라이언트 키는 브라우저 노출 OK(NEXT_PUBLIC_), 시크릿 키는 서버 전용(절대 노출 금지).
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_YOUR-TEST-CLIENT-KEY
TOSS_SECRET_KEY=test_sk_YOUR-TEST-SECRET-KEY

# ─── 기타 ───────────────────────────────────────────────────
# DEEPSEEK_API_KEY=...
# 샘플 친구 시드(localStorage mock 전용). 백엔드 전환 후엔 사용 안 함.
# NEXT_PUBLIC_SAMPLE_FRIENDS=1
